# Astro build-time env vars — copy to `.env` and fill in.
# `.env` is gitignored. For production, set these in the Cloudflare Pages
# dashboard under Settings → Environment variables.

# Multiplayer cursors WebSocket URL (deployed itsjan-cursors worker).
# If unset, the cursors feature gracefully no-ops.
PUBLIC_CURSORS_WSS=wss://itsjan-cursors.jleibl.workers.dev/ws
